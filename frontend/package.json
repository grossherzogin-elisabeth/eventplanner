{
    "name": "eventplanner-frontend",
    "private": true,
    "version": "1.3.2",
    "type": "module",
    "scripts": {
        "dev": "vite",
        "preview": "vite preview",
        "build": "vue-tsc --noEmit -p tsconfig.app.json --composite false && vite build",
        "lint": "npx eslint --fix src",
        "format": "./node_modules/.bin/prettier . --ignore-path .gitignore --ignore-path .prettierignore --write",
        "test": "TZ=CET vitest",
        "test:coverage": "TZ=CET vitest run --coverage",
        "check:format": "./node_modules/.bin/prettier --ignore-path .gitignore --ignore-path .prettierignore --check .",
        "check:lint": "npx eslint src",
        "check:typescript": "vue-tsc"
    },
    "dependencies": {
        "@fortawesome/fontawesome-free": "^7.2.0",
        "feiertagejs": "^1.5.1",
        "i18n-iso-countries": "^7.14.0",
        "i18n-nationality": "^1.4.0",
        "markdown-it": "^14.1.1",
        "svg-country-flags": "^1.2.10",
        "uuid": "^14.0.0",
        "vue-draggable-next": "^2.3.0",
        "vue-i18n": "^11.4.0",
        "vue-router": "^5.0.6",
        "vuedraggable": "^4.1.0"
    },
    "devDependencies": {
        "@babel/core": "^7.29.0",
        "@babel/preset-env": "^7.29.2",
        "@babel/preset-typescript": "^7.28.5",
        "@material/material-color-utilities": "^0.4.0",
        "@modyfi/vite-plugin-yaml": "^1.1.1",
        "@tailwindcss/postcss": "^4.2.4",
        "@trivago/prettier-plugin-sort-imports": "^6.0.2",
        "@types/markdown-it": "^14.1.2",
        "@types/node": "^24.12.2",
        "@types/uuid": "^11.0.0",
        "@vitejs/plugin-vue": "^6.0.6",
        "@vitest/coverage-v8": "^4.1.5",
        "@vue/eslint-config-typescript": "^14.7.0",
        "@vue/test-utils": "^2.4.9",
        "eslint": "^10.2.1",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-prettier": "^5.5.5",
        "eslint-plugin-vue": "^10.9.0",
        "fake-indexeddb": "^6.2.5",
        "happy-dom": "^20.9.0",
        "msw": "^2.13.6",
        "postcss": "^8.5.12",
        "prettier": "^3.8.3",
        "prettier-plugin-tailwindcss": "^0.8.0",
        "tailwindcss": "^4.2.2",
        "typescript": "^6.0.3",
        "typescript-eslint": "^8.59.1",
        "vite": "^7.3.1",
        "vite-plugin-pwa": "^1.2.0",
        "vite-svg-loader": "^5.1.1",
        "vitest": "^4.1.2",
        "vue": "^3.5.33",
        "vue-tsc": "^3.2.7"
    },
    "overrides": {
        "js-yaml": "^4.1.1",
        "serialize-javascript": "^7.0.4"
    }
}
